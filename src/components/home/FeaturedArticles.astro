---
import { getFeaturedArticles } from '../../data/articles';
import ArticleCard from '../revista/ArticleCard.astro';

const featuredArticles = getFeaturedArticles();
---

<section class="section bg-gray-50">
  <div class="container">
    <div class="text-center mb-12" data-aos="fade-up">
      <p class="text-humanic-green font-medium tracking-widest uppercase text-sm mb-3">Investigación de Excelencia</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-humanic-navy">Artículos Destacados</h2>
      <div class="mt-4 h-1 w-20 bg-gradient-to-r from-humanic-green to-humanic-lime rounded-full mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredArticles.map((article, index) => (
        <ArticleCard article={article} variant={index === 0 ? 'featured' : 'default'} />
      ))}
    </div>

    <div class="text-center mt-12" data-aos="fade-up">
      <a href="/revista" class="inline-flex items-center px-8 py-4 rounded-lg bg-gradient-to-r from-humanic-green to-humanic-navy text-white font-semibold hover:shadow-lg transition-all duration-300">
        Ver todos los artículos
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>