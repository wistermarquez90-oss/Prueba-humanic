---
const currentYear = new Date().getFullYear();

const footerLinks = {
  revista: [
    { label: 'Último Volumen', href: '/revista' },
    { label: 'Archivo', href: '/revista' },
    { label: 'Normas de Publicación', href: '/normas' },
    { label: 'Envío de Manuscritos', href: '/normas' }
  ],
  institucion: [
    { label: 'Quiénes Somos', href: '/nosotros' },
    { label: 'Directorio', href: '/autores' },
    { label: 'Líneas de Investigación', href: '/nosotros' },
    { label: 'Contacto', href: '/contacto' }
  ],
  recursos: [
    { label: 'Biblioteca Digital', href: '#' },
    { label: 'Bases de Datos', href: '#' },
    { label: 'Eventos', href: '#' },
    { label: 'Noticias', href: '#' }
  ]
};

const socialLinks = [
  { 
    label: 'Facebook', 
    href: 'https://facebook.com/humanic', 
    icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z'
  },
  { 
    label: 'Twitter', 
    href: 'https://twitter.com/humanic', 
    icon: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z'
  },
  { 
    label: 'Instagram', 
    href: 'https://instagram.com/humanic', 
    icon: 'M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M7.5 3h9a4.5 4.5 0 014.5 4.5v9a4.5 4.5 0 01-4.5 4.5h-9A4.5 4.5 0 013 16.5v-9A4.5 4.5 0 017.5 3z'
  },
  { 
    label: 'YouTube', 
    href: 'https://youtube.com/humanic', 
    icon: 'M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98l5.5 3.02-5.5 3.02z'
  }
];
---

<footer class="bg-humanic-dark text-white">
  <!-- Main Footer -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <div class="flex items-center space-x-3 mb-6">
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-humanic-green to-humanic-lime flex items-center justify-center">
            <span class="text-white font-bold text-xl">H</span>
          </div>
          <div>
            <span class="text-2xl font-bold text-white">HUMANIC</span>
            <span class="block text-xs text-humanic-bronze tracking-wider">Centro de Investigación</span>
          </div>
        </div>
        <p class="text-gray-400 mb-6 max-w-sm">
          Centro de investigación de la Universidad de Los Andes dedicado al estudio interdisciplinario de temas sociales, económicos y culturales. Editor de la revista científica FERMENTUM.
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center space-x-4">
          {socialLinks.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-gray-400 hover:bg-humanic-lime hover:text-humanic-dark transition-all duration-300"
              aria-label={social.label}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links Columns -->
      <div>
        <h4 class="text-white font-semibold mb-4">Revista FERMENTUM</h4>
        <ul class="space-y-3">
          {footerLinks.revista.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-humanic-lime transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Institución</h4>
        <ul class="space-y-3">
          {footerLinks.institucion.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-humanic-lime transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Recursos</h4>
        <ul class="space-y-3">
          {footerLinks.recursos.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-humanic-lime transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact Info -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm text-gray-400">
        <div class="flex items-start space-x-3">
          <svg class="w-5 h-5 text-humanic-lime flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>Av. 3 Independencia, Núcleo La Hechicera<br/>Edificio de Investigación, Piso 2<br/>Mérida 5101, Venezuela</span>
        </div>
        <div class="flex items-center space-x-3">
          <svg class="w-5 h-5 text-humanic-lime flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:info@humanic.ula.ve" class="hover:text-humanic-lime transition-colors">info@humanic.ula.ve</a>
        </div>
        <div class="flex items-center space-x-3">
          <svg class="w-5 h-5 text-humanic-lime flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span>+58 274 2401234</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-sm text-gray-500">
          © {currentYear} Centro de Investigación Humanic. Universidad de Los Andes. Todos los derechos reservados.
        </p>
        <div class="flex items-center space-x-6 text-sm text-gray-500">
          <a href="#" class="hover:text-white transition-colors">Política de Privacidad</a>
          <a href="#" class="hover:text-white transition-colors">Términos de Uso</a>
          <a href="#" class="hover:text-white transition-colors">Accesibilidad</a>
        </div>
      </div>
    </div>
  </div>
</footer>