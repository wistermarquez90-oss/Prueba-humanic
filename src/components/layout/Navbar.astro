---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Revista', href: '/revista' },
  { label: 'Autores', href: '/autores' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Normas', href: '/normas' },
  { label: 'Contacto', href: '/contacto' }
];

const currentPath = Astro.url.pathname;
---

<a href="#main-content" class="skip-nav">Saltar al contenido principal</a>

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100 transition-all duration-300" id="navbar">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 group">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-humanic-green to-humanic-lime flex items-center justify-center shadow-md group-hover:shadow-glow-lime transition-all duration-300">
          <span class="text-white font-bold text-lg">H</span>
        </div>
        <div class="flex flex-col">
          <span class="text-xl font-bold text-humanic-navy group-hover:text-humanic-green transition-colors">HUMANIC</span>
          <span class="text-xs text-humanic-bronze tracking-wider">Centro de Investigación</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-1">
        {navItems.map(item => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
                isActive
                  ? 'text-humanic-navy bg-humanic-lime/20'
                  : 'text-gray-600 hover:text-humanic-navy hover:bg-gray-100'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </div>

      <!-- CTA Button -->
      <div class="hidden lg:block">
        <a
          href="/revista"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-humanic-navy text-white font-medium text-sm hover:bg-humanic-navy-light transition-all duration-300 shadow-md hover:shadow-lg"
        >
          <span>Revista FERMENTUM</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="lg:hidden p-2 rounded-lg text-gray-600 hover:text-humanic-navy hover:bg-gray-100 transition-colors"
        id="mobile-menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div class="lg:hidden hidden" id="mobile-menu">
      <div class="py-4 space-y-2 border-t border-gray-100">
        {navItems.map(item => {
          const isActive = currentPath === item.href;
          return (
            <a
              href={item.href}
              class={`block px-4 py-3 rounded-lg font-medium transition-colors ${
                isActive
                  ? 'text-humanic-navy bg-humanic-lime/20'
                  : 'text-gray-600 hover:text-humanic-navy hover:bg-gray-100'
              }`}
            >
              {item.label}
            </a>
          );
        })}
        <div class="pt-4 px-4">
          <a
            href="/revista"
            class="flex items-center justify-center w-full px-5 py-3 rounded-lg bg-humanic-navy text-white font-medium hover:bg-humanic-navy-light transition-colors"
          >
            <span>Revista FERMENTUM</span>
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer para el navbar fijo -->
<div class="h-20"></div>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      mobileMenuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      mobileMenu.classList.toggle('hidden');
      menuIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });
  }

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > 50) {
      navbar?.classList.add('shadow-lg');
    } else {
      navbar?.classList.remove('shadow-lg');
    }
    
    lastScroll = currentScroll;
  });
</script>