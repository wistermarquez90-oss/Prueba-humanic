---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  variant?: 'home' | 'page';
  backgroundImage?: string;
  cta?: {
    label: string;
    href: string;
    variant?: 'primary' | 'secondary' | 'accent';
  };
  secondaryCta?: {
    label: string;
    href: string;
  };
}

const {
  title,
  subtitle,
  description,
  variant = 'page',
  backgroundImage,
  cta,
  secondaryCta
} = Astro.props;

const isHome = variant === 'home';
---

<section class={`relative ${isHome ? 'min-h-[90vh]' : 'min-h-[40vh]'} flex items-center justify-center overflow-hidden`}>
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-hero">
    {backgroundImage && (
      <div class="absolute inset-0 opacity-20">
        <img src={backgroundImage} alt="" class="w-full h-full object-cover" />
      </div>
    )}
    <!-- Decorative elements -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-64 h-64 bg-humanic-lime/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-humanic-green/20 rounded-full blur-3xl"></div>
    </div>
    <!-- Pattern overlay -->
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"1\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`${isHome ? 'max-w-4xl' : 'max-w-3xl'} mx-auto text-center`} data-aos="fade-up">
      {subtitle && (
        <p class="text-humanic-lime font-medium tracking-widest uppercase text-sm mb-4" data-aos="fade-up" data-aos-delay="100">
          {subtitle}
        </p>
      )}
      
      <h1 class={`${isHome ? 'text-4xl sm:text-5xl md:text-6xl lg:text-7xl' : 'text-3xl sm:text-4xl md:text-5xl'} font-bold text-white mb-6 leading-tight`} data-aos="fade-up" data-aos-delay="200">
        {title}
      </h1>
      
      {description && (
        <p class={`${isHome ? 'text-lg sm:text-xl' : 'text-base sm:text-lg'} text-gray-300 mb-8 leading-relaxed max-w-2xl mx-auto`} data-aos="fade-up" data-aos-delay="300">
          {description}
        </p>
      )}
      
      {(cta || secondaryCta) && (
        <div class={`flex ${isHome ? 'flex-col sm:flex-row' : 'flex-row'} items-center justify-center gap-4`} data-aos="fade-up" data-aos-delay="400">
          {cta && (
            <a
              href={cta.href}
              class={`inline-flex items-center px-8 py-4 rounded-lg font-semibold transition-all duration-300 shadow-lg hover:shadow-glow-lime ${
                cta.variant === 'accent' || !cta.variant
                  ? 'bg-gradient-to-r from-humanic-lime to-[#7cb342] text-humanic-dark'
                  : cta.variant === 'secondary'
                  ? 'bg-humanic-green text-white hover:bg-humanic-green-dark'
                  : 'bg-humanic-navy text-white hover:bg-humanic-navy-light'
              }`}
            >
              {cta.label}
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          )}
          
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center px-8 py-4 rounded-lg font-semibold text-white border-2 border-white/30 hover:border-white hover:bg-white/10 transition-all duration-300"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  {isHome && (
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2" data-aos="fade-up" data-aos-delay="600">
      <a href="#main-content" class="flex flex-col items-center text-white/70 hover:text-white transition-colors">
        <span class="text-sm mb-2">Descubre más</span>
        <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
    </div>
  )}
</section>