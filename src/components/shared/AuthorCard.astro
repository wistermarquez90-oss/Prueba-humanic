---
import type { Author } from '../../data/types';

interface Props {
  author: Author;
  variant?: 'default' | 'compact';
}

const { author, variant = 'default' } = Astro.props;

const { id, name, lastName, title, specialty, bio, affiliations, articles } = author;

const fullName = `${title} ${name} ${lastName}`;
const initials = `${name.charAt(0)}${lastName.charAt(0)}`;
---

<div class="bg-white rounded-xl shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-1 group" data-aos="fade-up">
  <div class="p-6">
    <!-- Header with Avatar -->
    <div class="flex items-start space-x-4 mb-4">
      <!-- Avatar -->
      <div class="flex-shrink-0">
        {author.photo ? (
          <img 
            src={author.photo} 
            alt={fullName}
            class="w-20 h-20 rounded-full object-cover border-3 border-humanic-lime"
          />
        ) : (
          <div class="w-20 h-20 rounded-full bg-gradient-to-br from-humanic-green to-humanic-lime flex items-center justify-center text-white text-xl font-bold border-3 border-white shadow-lg">
            {initials}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="flex-1 min-w-0">
        <h3 class="text-lg font-bold text-humanic-navy group-hover:text-humanic-green transition-colors truncate">
          {fullName}
        </h3>
        <p class="text-sm text-humanic-green font-medium">
          {specialty}
        </p>
        <p class="text-sm text-gray-500 mt-1">
          {affiliations[0]}
        </p>
      </div>
    </div>

    <!-- Bio -->
    <p class="text-gray-600 text-sm mb-4 line-clamp-3">
      {bio}
    </p>

    <!-- Stats -->
    <div class="flex items-center space-x-4 text-sm text-gray-500 mb-4">
      <span class="flex items-center">
        <svg class="w-4 h-4 mr-1 text-humanic-bronze" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        {articles.length} artículo{articles.length !== 1 ? 's' : ''}
      </span>
      {author.orcid && (
        <a 
          href={`https://orcid.org/${author.orcid}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center hover:text-humanic-green transition-colors"
        >
          <svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zM7.5 7.5h3v9h-3v-9zm4.5 0h3v1.5h-3V7.5zm0 3h3v6h-3v-6z"/>
          </svg>
          ORCID
        </a>
      )}
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
      <a 
        href={`/autores/${id}`}
        class="inline-flex items-center text-sm font-medium text-humanic-navy hover:text-humanic-green transition-colors"
      >
        Ver perfil completo
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      
      {author.email && (
        <a 
          href={`mailto:${author.email}`}
          class="text-gray-400 hover:text-humanic-green transition-colors"
          aria-label={`Enviar email a ${fullName}`}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</div>