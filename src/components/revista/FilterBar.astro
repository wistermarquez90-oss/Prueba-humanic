---
import { getUniqueYears, getUniqueTags } from '../../utils/helpers';
import { articles } from '../../data/articles';

interface Props {
  currentYear?: number | null;
  currentTag?: string | null;
  currentSearch?: string;
}

const { currentYear, currentTag, currentSearch } = Astro.props;

const years = getUniqueYears(articles);
const tags = getUniqueTags(articles);
---

<div class="bg-white rounded-xl shadow-card p-6 mb-8" data-aos="fade-up">
  <div class="flex flex-col lg:flex-row lg:items-center gap-4">
    <!-- Search -->
    <div class="flex-1">
      <label for="search" class="sr-only">Buscar artículos</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <input
          type="text"
          id="search"
          name="search"
          value={currentSearch || ''}
          placeholder="Buscar por título, autor o palabra clave..."
          class="block w-full pl-10 pr-3 py-3 border-2 border-gray-200 rounded-lg focus:border-humanic-green focus:ring-2 focus:ring-humanic-green/20 outline-none transition-all"
        />
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3">
      <!-- Year Filter -->
      <div class="relative">
        <select
          id="year"
          name="year"
          class="appearance-none bg-gray-50 border-2 border-gray-200 rounded-lg px-4 py-3 pr-10 focus:border-humanic-green focus:ring-2 focus:ring-humanic-green/20 outline-none transition-all cursor-pointer"
        >
          <option value="">Todos los años</option>
          {years.map(year => (
            <option value={year} selected={currentYear === year}>{year}</option>
          ))}
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
          <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>

      <!-- Tag Filter -->
      <div class="relative">
        <select
          id="tag"
          name="tag"
          class="appearance-none bg-gray-50 border-2 border-gray-200 rounded-lg px-4 py-3 pr-10 focus:border-humanic-green focus:ring-2 focus:ring-humanic-green/20 outline-none transition-all cursor-pointer"
        >
          <option value="">Todas las áreas</option>
          {tags.map(tag => (
            <option value={tag} selected={currentTag === tag}>{tag}</option>
          ))}
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
          <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>

      <!-- Clear Button -->
      {(currentYear || currentTag || currentSearch) && (
        <a
          href="/revista"
          class="inline-flex items-center px-4 py-3 rounded-lg border-2 border-gray-200 text-gray-600 hover:border-humanic-green hover:text-humanic-green transition-all"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Limpiar
        </a>
      )}
    </div>
  </div>

  <!-- Active Filters -->
  {(currentYear || currentTag || currentSearch) && (
    <div class="flex flex-wrap items-center gap-2 mt-4 pt-4 border-t border-gray-100">
      <span class="text-sm text-gray-500">Filtros activos:</span>
      {currentYear && (
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-humanic-navy/10 text-humanic-navy">
          Año: {currentYear}
          <button type="button" class="ml-2 hover:text-red-500" onclick="document.getElementById('year').value='';this.closest('form')?.submit()">×</button>
        </span>
      )}
      {currentTag && (
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-humanic-green/10 text-humanic-green">
          {currentTag}
          <button type="button" class="ml-2 hover:text-red-500" onclick="document.getElementById('tag').value='';this.closest('form')?.submit()">×</button>
        </span>
      )}
      {currentSearch && (
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-humanic-lime/20 text-humanic-dark">
          "{currentSearch}"
          <button type="button" class="ml-2 hover:text-red-500" onclick="document.getElementById('search').value='';this.closest('form')?.submit()">×</button>
        </span>
      )}
    </div>
  )}
</div>

<script>
  // Auto-submit on filter change
  document.querySelectorAll('#year, #tag').forEach(select => {
    select.addEventListener('change', (e) => {
      const form = (e.target as HTMLElement).closest('form');
      if (form) form.submit();
    });
  });

  // Debounced search
  let searchTimeout: ReturnType<typeof setTimeout>;
  document.getElementById('search')?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      const form = (e.target as HTMLElement).closest('form');
      if (form) form.submit();
    }, 500);
  });
</script>