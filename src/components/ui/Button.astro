---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'accent';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  target?: string;
  rel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  class: className = '',
  target,
  rel
} = Astro.props;

// Classes base
const baseClasses = 'inline-flex items-center justify-center font-medium transition-all duration-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed';

// Variantes
const variantClasses = {
  primary: 'bg-humanic-navy text-white hover:bg-humanic-navy-light focus:ring-humanic-navy shadow-md hover:shadow-lg',
  secondary: 'bg-humanic-green text-white hover:bg-humanic-green-dark focus:ring-humanic-green shadow-md hover:shadow-lg',
  outline: 'border-2 border-humanic-navy text-humanic-navy hover:bg-humanic-navy hover:text-white focus:ring-humanic-navy',
  ghost: 'text-humanic-navy hover:bg-humanic-navy/10 focus:ring-humanic-navy',
  accent: 'bg-gradient-to-r from-humanic-lime to-[#7cb342] text-humanic-dark font-semibold hover:shadow-glow-lime focus:ring-humanic-lime'
};

// Tamaños
const sizeClasses = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-base',
  lg: 'px-8 py-3.5 text-lg'
};

const finalClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

{href ? (
  <a href={href} class={finalClasses} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class={finalClasses}>
    <slot />
  </button>
)}