---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'outline' | 'default';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  class: className = ''
} = Astro.props;

const baseClasses = 'inline-flex items-center rounded-full font-medium transition-colors';

const variantClasses = {
  primary: 'bg-humanic-navy/10 text-humanic-navy hover:bg-humanic-navy hover:text-white',
  secondary: 'bg-humanic-green/10 text-humanic-green hover:bg-humanic-green hover:text-white',
  accent: 'bg-humanic-lime/20 text-humanic-dark hover:bg-humanic-lime',
  outline: 'border border-humanic-navy/30 text-humanic-navy hover:bg-humanic-navy hover:text-white',
  default: 'bg-gray-100 text-gray-700 hover:bg-gray-200'
};

const sizeClasses = {
  sm: 'px-2.5 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm'
};

const finalClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

<span class={finalClasses}>
  <slot />
</span>