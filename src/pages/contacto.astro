---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/layout/Hero.astro';
import SectionTitle from '../components/shared/SectionTitle.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';
---

<MainLayout title="Contacto" description="Contacta al Centro de Investigación Humanic. Dirección, correos electrónicos, teléfonos y formulario de contacto.">
  <Hero
    variant="page"
    title="Contacto"
    subtitle="Estamos para Ayudarte"
    description="¿Tienes preguntas sobre publicaciones, colaboraciones o el centro? Escríbenos y te responderemos pronto."
  />

  <section class="section bg-gray-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="bg-white rounded-2xl shadow-card p-8" data-aos="fade-right">
          <SectionTitle title="Envíanos un Mensaje" centered={false} />
          
          <form class="space-y-6" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <div class="grid md:grid-cols-2 gap-6">
              <Input
                label="Nombre completo"
                name="name"
                type="text"
                placeholder="Tu nombre"
                required
              />
              <Input
                label="Correo electrónico"
                name="email"
                type="email"
                placeholder="tu@email.com"
                required
              />
            </div>

            <Input
              label="Institución / Afiliación"
              name="institution"
              type="text"
              placeholder="Universidad o institución"
            />

            <Input
              label="Asunto"
              name="subject"
              type="select"
              options={[
                { value: 'publicacion', label: 'Consulta sobre publicación' },
                { value: 'colaboracion', label: 'Propuesta de colaboración' },
                { value: 'suscripcion', label: 'Suscripción a la revista' },
                { value: 'general', label: 'Consulta general' },
                { value: 'otro', label: 'Otro' }
              ]}
              required
            />

            <Input
              label="Mensaje"
              name="message"
              type="textarea"
              placeholder="Escribe tu mensaje aquí..."
              rows={5}
              required
            />

            <div class="flex items-start">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 w-4 h-4 text-humanic-green border-gray-300 rounded focus:ring-humanic-green"
              />
              <label for="privacy" class="ml-3 text-sm text-gray-600">
                Acepto la <a href="#" class="text-humanic-green hover:underline">política de privacidad</a> y el tratamiento de mis datos para responder mi consulta.
              </label>
            </div>

            <Button variant="primary" type="submit" class="w-full justify-center">
              Enviar mensaje
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </Button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8" data-aos="fade-left">
          <!-- Direct Contact Cards -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-6 shadow-card hover:shadow-card-hover transition-all">
              <div class="w-12 h-12 bg-humanic-green/10 rounded-xl flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-humanic-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="font-bold text-humanic-navy mb-2">Correo General</h3>
              <a href="mailto:info@humanic.ula.ve" class="text-humanic-green hover:text-humanic-navy transition-colors">
                info@humanic.ula.ve
              </a>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card hover:shadow-card-hover transition-all">
              <div class="w-12 h-12 bg-humanic-bronze/10 rounded-xl flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-humanic-bronze" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
              <h3 class="font-bold text-humanic-navy mb-2">Editorial</h3>
              <a href="mailto:editor@humanic.ula.ve" class="text-humanic-bronze hover:text-humanic-navy transition-colors">
                editor@humanic.ula.ve
              </a>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card hover:shadow-card-hover transition-all">
              <div class="w-12 h-12 bg-humanic-lime/20 rounded-xl flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-humanic-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <h3 class="font-bold text-humanic-navy mb-2">Teléfono</h3>
              <p class="text-gray-600">+58 274 2401234</p>
              <p class="text-sm text-gray-500">Ext. 245 (Editorial)</p>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card hover:shadow-card-hover transition-all">
              <div class="w-12 h-12 bg-humanic-navy/10 rounded-xl flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-humanic-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="font-bold text-humanic-navy mb-2">Horario</h3>
              <p class="text-gray-600">Lunes - Viernes</p>
              <p class="text-sm text-gray-500">8:00 AM - 4:00 PM (VET)</p>
            </div>
          </div>

          <!-- Address -->
          <div class="bg-white rounded-xl p-8 shadow-card">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-humanic-green/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-humanic-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-humanic-navy mb-2">Dirección</h3>
                <p class="text-gray-600 mb-4">
                  Centro de Investigación Humanic<br/>
                  Universidad de Los Andes<br/>
                  Av. 3 Independencia, Núcleo La Hechicera<br/>
                  Edificio de Investigación, Piso 2<br/>
                  Mérida 5101, Venezuela
                </p>
                <a 
                  href="https://maps.google.com/?q=Universidad+de+Los+Andes+Mérida"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-humanic-green hover:text-humanic-navy transition-colors"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Ver en Google Maps
                </a>
              </div>
            </div>
          </div>

          <!-- Social Media -->
          <div class="bg-gradient-to-br from-humanic-navy to-humanic-dark rounded-xl p-8 text-white">
            <h3 class="font-bold text-xl mb-4">Síguenos en Redes</h3>
            <p class="text-gray-300 mb-6">
              Mantente al día con nuestras publicaciones, eventos y novedades académicas.
            </p>
            <div class="flex flex-wrap gap-4">
              {[
                { name: 'Facebook', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z', url: 'https://facebook.com/humanic' },
                { name: 'Twitter', icon: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z', url: 'https://twitter.com/humanic' },
                { name: 'Instagram', icon: 'M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M7.5 3h9a4.5 4.5 0 014.5 4.5v9a4.5 4.5 0 01-4.5 4.5h-9A4.5 4.5 0 013 16.5v-9A4.5 4.5 0 017.5 3z', url: 'https://instagram.com/humanic' },
                { name: 'YouTube', icon: 'M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98l5.5 3.02-5.5 3.02z', url: 'https://youtube.com/humanic' }
              ].map(social => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center hover:bg-humanic-lime hover:text-humanic-dark transition-all"
                  aria-label={social.name}
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d={social.icon}/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="h-96 bg-gray-200 relative">
    <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-humanic-navy/90 to-humanic-dark/90">
      <div class="text-center text-white">
        <svg class="w-16 h-16 mx-auto mb-4 text-humanic-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <h3 class="text-2xl font-bold mb-2">Universidad de Los Andes</h3>
        <p class="text-gray-300">Mérida, Venezuela</p>
        <a 
          href="https://maps.google.com/?q=Universidad+de+Los+Andes+Mérida+Venezuela"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center mt-4 px-6 py-3 rounded-lg bg-humanic-lime text-humanic-dark font-semibold hover:shadow-glow-lime transition-all"
        >
          Abrir en Google Maps
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</MainLayout>